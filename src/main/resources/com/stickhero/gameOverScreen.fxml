<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.TextFlow?>


<?import javafx.scene.control.Label?>
<AnchorPane fx:controller="com.stickhero.GameOverController" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>

      <ImageView fitHeight="400.0" fitWidth="700.0">
         <image>
            <Image url="@Images/gameBg.jpeg" />
         </image>
      </ImageView>

      <Label text= "Your Score:"
             layoutX="250" layoutY="120"
             style="-fx-font-size: 18px; -fx-font-weight: bold"
             textFill="#4a2d00"/>


      <Label fx:id="finalScoreLabel"
             layoutX="390.0" layoutY="110"
             style="-fx-font-size: 28px; -fx-font-weight: bold;"
             textFill="#4a2d00"
      />

      <Label text="Avocados:"
              layoutX="250"
              layoutY="160"
              style="-fx-font-size: 18px; -fx-font-weight: bold;"
             textFill="#4a2d00"/>

      <Label fx:id="finalAvocadoLabel"
              layoutX="390"
              layoutY="150"
              style="-fx-font-size: 28px; -fx-font-weight: bold;"
              textFill="#4a2d00"/>

      <ImageView fitHeight="43.0" fitWidth="370.0"
                 layoutX="155.0" layoutY="37.0">
         <image>
            <Image url="@Images/gameOverText.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="84.0" fitWidth="113.0"
                 layoutX="290.0" layoutY="227.0">
         <image>
            <Image url="@Images/Falling.png" />
         </image>
      </ImageView>

      <ImageView fx:id="restartImage"
                 fitHeight="80.0" fitWidth="80.0"
                 layoutX="525.0" layoutY="187.0"
                 onMouseClicked = "#restartGame">
         <image>
            <Image url="@Images/retry.png" />
         </image>

      </ImageView>

      <ImageView fx:id = "menuImage"
                 fitHeight="80.0" fitWidth="80.0"
                 layoutX="90.0" layoutY="187.0"
                 onMouseClicked = "#goToMenu">
         <image>
            <Image url="@Images/exit.png"/>
         </image>
      </ImageView>

   </children>
</AnchorPane>
