<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.TextFlow?>


<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<AnchorPane fx:controller="com.stickhero.MainScreenController" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <ImageView fitHeight="400.0"
                 fitWidth="700.0">
         <image>
            <Image url="@Images/gameBg.jpeg" />
         </image>
      </ImageView>

      <ImageView fitHeight="52.0"
                 fitWidth="289.0"
                 layoutX="200.0"
                 layoutY="44.0">
         <image>
            <Image url="@Images/title.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="122.0"
                 fitWidth="122.0"
                 layoutX="275.0"
                 layoutY="192.0">
         <image>
            <Image url="@Images/Idlestand.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="52.0"
                 fitWidth="55.0"
                 layoutX="500.0"
                 layoutY="269.0">
         <image>
            <Image url="@Images/avocado.png" />
         </image>
      </ImageView>

      <ImageView fx:id = "playImage"
                 fitHeight="88.0"
                 fitWidth="88.0"
                 layoutX="290.0"
                 layoutY="124.0"
                 onMouseClicked="#startGame">
         <image>
            <Image url="@Images/play.png" />
         </image>
      </ImageView>

      <ImageView fx:id="scoreListImage"
                 fitHeight="45.0"
                 fitWidth="46.0"
                 layoutX="14.0"
                 layoutY="70.0"
                 onMouseClicked="#showLeaderboard"
      >
         <image>
            <Image url="@Images/topScores.png" />
         </image>
      </ImageView>

      <AnchorPane fx:id="leaderboardOverlay"
                  visible="false"
                  prefWidth="700"
                  prefHeight="400"
                  style="-fx-background-color: rgba(0,0,0,0.9);">

         <children>
            <VBox fx:id="leaderboardBox"
                  alignment="CENTER"
                  spacing="10"
                  layoutX="150"
                  layoutY="50"
                  prefWidth="400">

               <children>

                  <Label text="HIGH SCORES"
                         style="-fx-font-size: 24px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>

               </children>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="15"
                  layoutX="100"
                  layoutY="300"
                  prefWidth="500">
               <children>
                  <ImageView fitWidth="80"
                             preserveRatio="true"
                             onMouseClicked="#hideLeaderboard">
                     <image>
                        <Image url="@Images/close.png"/>
                     </image>
                  </ImageView>
               </children>
            </VBox>
         </children>
      </AnchorPane>

      <ImageView fitHeight="45.0"
                 fitWidth="46.0"
                 layoutX="14.0"
                 layoutY="14.0">
         <image>
            <Image url="@Images/soundOn.png" />
         </image>
      </ImageView>

      <ImageView fx:id="infoImage"
                 fitHeight="45.0"
                 fitWidth="46.0"
                 layoutX="640.0"
                 layoutY="14.0"
                 onMouseClicked="#showInstructions"
      >
         <image>
            <Image url="@Images/info.png" />
         </image>
      </ImageView>

      <AnchorPane fx:id="instructionsOverlay"
                  visible="false"
                  prefWidth="700"
                  prefHeight="400"
                  style="-fx-background-color: rgba(0,0,0,0.9);">

         <children>
            <VBox alignment="CENTER"
                  spacing="15"
                  layoutX="100"
                  layoutY="20"
                  prefWidth="500">
               <children>
                  <Label text="HOW TO PLAY"
                         style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
               </children>
            </VBox>

            <VBox alignment="CENTER_LEFT"
                  spacing="15"
                  layoutX="100"
                  layoutY="80"
                  prefWidth="500">

               <children>
                  <Label text="- Hold SPACE to extend the stick."
                         style="-fx-font-size: 15px; -fx-text-fill: white;"/>
                  <Label text="- Release SPACE to drop the stick."
                         style="-fx-font-size: 15px; -fx-text-fill: white;"/>
                  <Label text="- Reach the next platform."
                         style="-fx-font-size: 15px; -fx-text-fill: white;"/>
                  <Label text="- Press SPACE while running to flip."
                         style="-fx-font-size: 15px; -fx-text-fill: white;"/>
                  <Label text="- Collect avocados for bonus points."
                         style="-fx-font-size: 15px; -fx-text-fill: white;"/>
                  <Label text="- Landing while upside-down ends the game."
                         style="-fx-font-size: 15px; -fx-text-fill: white;"/>
               </children>

            </VBox>

            <VBox alignment="CENTER"
                  spacing="15"
                  layoutX="100"
                  layoutY="300"
                  prefWidth="500">
               <children>
                  <ImageView fitWidth="80"
                             preserveRatio="true"
                             onMouseClicked="#hideInstructions">
                     <image>
                        <Image url="@Images/close.png"/>
                     </image>
                  </ImageView>
               </children>
            </VBox>
         </children>
      </AnchorPane>
      <AnchorPane fx:id="usernameOverlay"
                  visible="false"
                  prefWidth="700"
                  prefHeight="400"
                  style="-fx-background-color: rgba(0,0,0,0.8);">

         <children>

            <VBox alignment="CENTER"
                  spacing="20"
                  layoutX="150"
                  layoutY="120"
                  prefWidth="400">

               <children>

                  <Label text="ENTER USERNAME"
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                  <TextField fx:id="usernameField"
                             maxWidth="250"
                             promptText="Username"
                             onAction="#confirmStartGame"
                  />

                  <Button text="Enter"
                          onAction="#confirmStartGame"
                          prefWidth="100"
                          defaultButton="true"
                  />

               </children>
            </VBox>
         </children>
      </AnchorPane>

   </children>
</AnchorPane>
