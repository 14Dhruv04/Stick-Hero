<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.TextFlow?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<AnchorPane fx:id = "gamePane" fx:controller="com.stickhero.GameController" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>

      <ImageView fitHeight="400.0"
                 fitWidth="700.0">
         <image>
            <Image url="@Images/gameBg.jpeg" />
         </image>
      </ImageView>

      <Rectangle fx:id="leftPlatform"
                 arcWidth="3.0"
                 fill="#0a4b0a"
                 height="139.0"
                 layoutX="14.0"
                 layoutY="261.0"
                 stroke="#0a4b0a"
                 strokeType="INSIDE"
                 width="121.0"
      />

      <ImageView fx:id="heroImage"
                 fitHeight="66.0"
                 fitWidth="66.0"
                 layoutX="42.0"
                 layoutY="195.0">
         <image>
            <Image url= "@Images/Idlestand.png" />
         </image>
      </ImageView>

      <Label fx:id="scoreLabel"
             layoutX="350.0"
             layoutY="20.0"
             prefHeight="100.0"
             prefWidth="100.0"
             text = "0"
             style = "-fx-font-size: 32px; -fx-font-weight: bold;"
             textFill="#4a2d00"
      />

      <ImageView fitHeight="45.0"
                 fitWidth="45.0"
                 layoutX="6.0"
                 layoutY="6.0"
                 onMouseClicked="#pauseGame">
         <image>
            <Image url= "@Images/pause.png" />
         </image>
      </ImageView>

      <ImageView fitHeight="45.0"
                 fitWidth="45.0"
                 layoutX="650"
                 layoutY="7">
         <image>
            <Image url="@Images/avocado.png"/>
         </image>
      </ImageView>

      <Label fx:id="avocadoLabel"
             layoutX="635"
             layoutY="20"
             text="0"
             style="-fx-font-size: 18px; -fx-font-fill: #FF0000; -fx-font-weight: bold;"
             textFill="#4a2d00"
      />

      <Line fx:id="stickLine"
            endX="0"
            endY="0"
            layoutX="120"
            layoutY="260"
            opacity="0.83"
            startX="0"
            startY="0"
            strokeWidth="4.0"
      />

      <AnchorPane fx:id="pauseOverlay" visible="false" prefWidth="700" prefHeight="400" style="-fx-background-color: rgba(0,0,0,0.6);">
         <children>
            <VBox alignment="CENTER"
                  spacing="25"
                  layoutX="250"
                  layoutY="80">

               <children>
                  <ImageView
                          fx:id="resumeImage"
                          fitWidth="200"
                          fitHeight="60"
                          onMouseClicked="#resumeGame">

                     <image>
                        <Image url="@Images/resume.png"/>
                     </image>
                  </ImageView>

                  <ImageView
                          fx:id="restartImage"
                          fitWidth="180"
                          fitHeight="40"
                          onMouseClicked="#restartGame">

                     <image>
                        <Image url="@Images/restart.png"/>
                     </image>
                  </ImageView>

                  <ImageView
                          fx:id="quitImage"
                          fitWidth="200"
                          fitHeight="60"
                          onMouseClicked="#quitGame">

                     <image>
                        <Image url="@Images/quit.png"/>
                     </image>
                  </ImageView>

               </children>
            </VBox>
         </children>
      </AnchorPane>

   </children>
</AnchorPane>
